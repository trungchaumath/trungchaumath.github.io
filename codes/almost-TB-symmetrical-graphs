from itertools import combinations
from collections import defaultdict

NUM_VERTICES   = 9
CONNECTED_ONLY = True

# Index range of valid (filtered) graphs to check.
# Both are 0-based. Set START_INDEX=0 and END_INDEX=None
# to check everything. Otherwise e.g. 1234 to 2345:
START_INDEX = 0
END_INDEX   = None   # inclusive; set None to go to the end

def has_pendant_vertex(G):
    return any(G.degree(v) == 1 for v in G.vertices())


def is_valid_graph(G):
    if G.is_tree():                    return False
    if has_pendant_vertex(G):          return False
    return True

def get_cycles_by_length(G):
    raw = G.all_simple_cycles()
    by_len = defaultdict(list)
    for c in raw:
        length = len(c) - 1
        if length >= 3:
            by_len[length].append(tuple(c))
    return by_len

def edge_orientation_in_cycle(a, b, cycle):
    n = len(cycle) - 1
    for i in range(n):
        u, v = cycle[i], cycle[i + 1]
        if u == a and v == b: return 'forward'
        if u == b and v == a: return 'backward'
    return None

def cycles_through_edge(e, cycle_list):
    a, b = e
    return sum(1 for c in cycle_list
               if edge_orientation_in_cycle(a, b, c) is not None)

def cycles_through_two_edges(e1, e2, cycle_list):
    a1, b1 = e1
    a2, b2 = e2
    return sum(1 for c in cycle_list
               if edge_orientation_in_cycle(a1, b1, c) is not None
               and edge_orientation_in_cycle(a2, b2, c) is not None)
    
def check_almost_rs(G, r, s, cycles_r, cycles_s):
    edges = list(G.edges(labels=False))
    a  = {e: cycles_through_edge(e, cycles_s) for e in edges}
    ra = {e: cycles_through_edge(e, cycles_r) for e in edges}
    rho = None
    for e in edges:
        ae, rae = a[e], ra[e]
        if ae == 0:
            if rae != 0: return False, None
        else:
            if rae % ae != 0: return False, None
            rho_e = rae // ae
            if rho is None:   rho = rho_e
            elif rho != rho_e: return False, None
    if rho is None: rho = 0
    adj_pairs = [(edges[i], edges[j])
                 for i in range(len(edges))
                 for j in range(i + 1, len(edges))
                 if len(set(edges[i]) & set(edges[j])) > 0]
    for (e1, e2) in adj_pairs:
        cp  = cycles_through_two_edges(e1, e2, cycles_s)
        rcp = cycles_through_two_edges(e1, e2, cycles_r)
        if cp == 0:
            if rcp != 0: return False, None
        else:
            if rcp % cp != 0 or rcp // cp != rho:
                return False, None
    return True, rho

def is_almost_TB_symmetrical(G):
    if is_valid_graph(G)==false: return False
    by_len = get_cycles_by_length(G)
    lengths = sorted(by_len.keys())
    if len(lengths) < 2: return False
    for r, s in combinations(lengths, 2):
        ok_rs, _ = check_almost_rs(G, r, s, by_len[r], by_len[s])
        if ok_rs: continue
        ok_sr, _ = check_almost_rs(G, s, r, by_len[s], by_len[r])
        if ok_sr: continue
        return False
    return True

flag = "-c" if CONNECTED_ONLY else ""
all_graphs = list(graphs.nauty_geng(
    f"{NUM_VERTICES} {flag}".strip()))

valid_graphs = all_graphs

total_valid = len(valid_graphs)
end = END_INDEX + 1 if END_INDEX is not None else None
batch = valid_graphs[START_INDEX:end]

print(f"Total graphs (raw):         {len(all_graphs)}")
print(f"Checking indices {START_INDEX} to "
      f"{END_INDEX if END_INDEX is not None else total_valid-1} "
      f"({len(batch)} graphs)")

almost_tb_list = []
for i, G in enumerate(batch):
    G.relabel()
    if is_almost_TB_symmetrical(G):
        almost_tb_list.append((START_INDEX + i, G))
    if (i + 1) % 100 == 0:
        print(f"  ... checked {i+1}/{len(batch)}")

print(f"Almost-TB-symmetrical found: {len(almost_tb_list)}")

if almost_tb_list:
    cols = 4
    rows = ceil(len(almost_tb_list) / cols)
    arr = graphics_array(
        [G.plot(title=f"#{idx} |V|={G.order()} |E|={G.size()}")
         for idx, G in almost_tb_list],
        nrows=rows, ncols=cols)
    fname = f"almost_TB_{START_INDEX}_to_{END_INDEX}.png"
    arr.save(fname, figsize=[4*cols, 4*rows])
    print(f"Saved: {fname}")
